DATABASE_URL="postgresql://neondb_owner:npg_Iirz5gFaB9lv@ep-fancy-smoke-abee81rz-pooler.eu-west-2.aws.neon.tech/neondb?channel_binding=require&sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-this"

# ── Google OAuth ──────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── GitHub OAuth ──────────────────────────────────────────────────────
# Create at https://github.com/settings/developers → New OAuth App
# Callback URL: https://yourdomain.com/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""

# ── Vercel Blob ───────────────────────────────────────────────────────
# Required for book file uploads (PDF / EPUB / TXT, up to 100 MB)
# Get from: Vercel Dashboard → your project → Storage → Blob → .env.local tab
BLOB_READ_WRITE_TOKEN=""

# ── Email (Resend) ────────────────────────────────────────────────────
# Required for email verification on registration
# Get API key from: https://resend.com → API Keys
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=""
# From address — must be from a domain you've verified in Resend dashboard
# For testing you can use: onboarding@resend.dev (only delivers to Resend account owner email)
RESEND_FROM="我们真的爱读书 <noreply@yourdomain.com>"
# Public URL of your app — used to build verification links in emails
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
