# ── Database ─────────────────────────────────────────────────────────
# PostgreSQL (Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL="postgresql://user:password@host:5432/bookshare?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-this"

# ── Google OAuth ──────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── GitHub OAuth ──────────────────────────────────────────────────────
# Create at https://github.com/settings/developers → New OAuth App
# Callback URL: https://yourdomain.com/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""
