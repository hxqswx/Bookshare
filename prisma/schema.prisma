// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  avatar        String?
  bio           String?
  readingGoal   Int       @default(12)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  posts         Post[]
  comments      Comment[]
  likes         Like[]
  readingList   UserBook[]
}

model Book {
  id          String   @id @default(cuid())
  title       String
  titleZh     String?
  author      String
  authorZh    String?
  cover       String?
  description String?
  descriptionZh String?
  genre       String?
  isbn        String?
  publishYear Int?
  createdAt   DateTime @default(now())

  posts       Post[]
  userBooks   UserBook[]
}

model UserBook {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  status    String   @default("want_to_read") // want_to_read, reading, finished
  progress  Int      @default(0) // 0-100
  rating    Int?     // 1-5
  review    String?
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

model Post {
  id        String   @id @default(cuid())
  userId    String
  bookId    String?
  content   String
  type      String   @default("share") // share, review, progress, quote
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book?    @relation(fields: [bookId], references: [id], onDelete: SetNull)
  comments  Comment[]
  likes     Like[]
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}
